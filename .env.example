# --- Server ---
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Public URL where this server is reachable. Used to build OAuth redirect_uri.
# For dev with ngrok: https://your-name.ngrok-free.app
SERVER_PUBLIC_URL=http://localhost:3000

# --- Database ---
# Dev: SQLite file (zero ops). Swap to postgresql://... in prod.
DATABASE_URL=file:./synapse.db

# --- Auth (JWT) ---
# Must match the JWT secret stored in Salesforce SynapseConfig__mdt.JwtSecret__c.
# Generate one: openssl rand -hex 32
JWT_SECRET=replace-me-with-a-32-byte-hex-secret
JWT_ALG=HS256

# --- AI providers ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- Salesforce (server-side bootstrap, optional) ---
# Used as the fallback jsforce connection when a Salesforce CRM tool runs
# WITHOUT a connector. With a connector (recommended path), tokens come
# from the Connector table — these env vars don't matter.
SF_LOGIN_URL=https://login.salesforce.com
SF_CLIENT_ID=
SF_CLIENT_SECRET=

# --- Salesforce MCP connector (OAuth) ---
# External Client App / Connected App that admins authorize when they
# click Connect on the Salesforce MCP tile in the portal. Reuse the SAME
# Connected App your standalone MCP server uses so tokens work for both.
SF_MCP_CLIENT_ID=
SF_MCP_CLIENT_SECRET=

# --- Salesforce MCP — standalone server URL ---
# Public URL of the standalone Salesforce MCP server (from `Salesforce MCP Server/`).
# Tool calls forward here with the user's OAuth access token as Bearer.
SF_REMOTE_MCP_URL=https://your-name.ngrok-free.app

# --- Platform Event callback ---
SF_CALLBACK_PLATFORM_EVENT=AgentExecutionResult__e

# --- Google OAuth (Gmail connector) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
