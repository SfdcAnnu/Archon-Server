{
  "name": "synapse-ai-server",
  "version": "0.1.0",
  "description": "Synapse AI execution engine — runs agent graphs, calls MCP servers, talks to Claude/GPT.",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "prisma generate",
    "start": "prisma migrate deploy && tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "lint": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@google/generative-ai": "^0.21.0",
    "@modelcontextprotocol/sdk": "^1.10.2",
    "@prisma/client": "^5.22.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsforce": "^3.4.1",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.65.0",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.7.4",
    "pino-pretty": "^11.2.2",
    "typescript": "^5.6.2"
  }
}
